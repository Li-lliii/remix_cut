# 复制一份为 .env 后再执行 ./start

# MinIO 对象存储，AI 变身素材和结果会保存到这个 bucket。
BS_MEDIA_MINIO_ACCESS_KEY=bs_media
BS_MEDIA_MINIO_SECRET_KEY=bs_media_password
BS_MEDIA_MINIO_BUCKET=bs-media
BS_MEDIA_MINIO_SECURE=false
BS_MEDIA_MINIO_PRESIGN_EXPIRY_SEC=3600

# Celery / Redis / RabbitMQ 在 docker-compose.yml 里已经指向容器名。
BS_MEDIA_REDIS_URL=redis://redis:6379/0
BS_MEDIA_CELERY_BROKER_URL=amqp://bs_media:bs_media@rabbitmq:5672//
BS_MEDIA_CELERY_RESULT_BACKEND=redis://redis:6379/0

# 当前 ai_transforms 仓储仍使用 SQLite；生产高并发前再迁 PostgreSQL。
BS_MEDIA_UID=1000
BS_MEDIA_GID=1000
BS_MEDIA_DATA_DIR=/app/metahuman_platform/data
BS_MEDIA_UPLOADS_DIR=/app/metahuman_platform/uploads
BS_MEDIA_WORK_DIR=/app/metahuman_platform/work

# ComfyUI 本体通常单独部署在 GPU 环境。
# 如果 ComfyUI 跑在宿主机，把 config.yaml 里的 comfyui.server_address 改成 host.docker.internal:端口。
# 如果 ComfyUI 也在 compose 网络里，把它改成 comfyui:端口。
BS_MEDIA_COMFY_SERVICE_HOST=comfyui-gateway
BS_MEDIA_COMFY_SERVICE_PORT=7002
BS_MEDIA_COMFY_MODE=service
BS_MEDIA_REPLACE_SPEECH_WORKFLOW_PATH=/app/workstream/ai_transforms/replace_speech_api.json

# ASR/TTS 如果还跑在宿主机，对应服务地址使用 host.docker.internal。
BS_MEDIA_ASR_SERVICE_HOST=host.docker.internal
BS_MEDIA_ASR_SERVICE_PORT=7000
BS_MEDIA_TTS_SERVICE_HOST=host.docker.internal
BS_MEDIA_TTS_SERVICE_PORT=7001
BS_MEDIA_QWEN3_TTS_ROOT=/app/Qwen3-TTS
BS_MEDIA_QWEN3_TTS_MODEL=/app/Qwen3-TTS/Qwen3-TTS-12Hz-1.7B-Base
